---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  caption: string;
}

const { src, alt, caption } = Astro.props;
---

<figure
  class="screenshot-frame flex flex-col items-center gap-2 rounded-3xl border border-dashed border-gray-300 bg-white px-4 py-6 shadow-sm"
>
  <div
    class="screenshot-frame__image flex aspect-9/19 w-full items-center justify-center rounded-3xl bg-gray-50 text-xs text-gray-400"
  >
    <Image src={src} alt={alt} class="rounded-3xl" />
  </div>
  <figcaption class="text-xs text-gray-600">{caption}</figcaption>
</figure>

<style>
  .screenshot-frame {
    height: 100%;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }
  .screenshot-frame__image {
    flex: 1;
    min-height: 0;
    aspect-ratio: unset;
  }
  .screenshot-frame__image img {
    width: auto;
    height: 100%;
    max-height: 100%;
    object-fit: contain;
  }
</style>
