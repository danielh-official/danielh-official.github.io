---
import { Image } from "astro:assets";

const { src, alt, width, height, caption } = Astro.props;
---

<figure
  class="flex flex-col items-center gap-2 rounded-3xl border border-dashed border-gray-300 bg-white px-4 py-6 shadow-sm"
>
  <div
    class="flex aspect-9/19 w-full items-center justify-center rounded-3xl border border-gray-200 bg-gray-50 text-xs text-gray-400"
  >
    <Image src={src} alt={alt} width={width} height={height} />
  </div>
  <figcaption class="text-xs text-gray-600">{caption}</figcaption>
</figure>
