---
import "../styles/global.css";
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <slot name="favicon">
      <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    </slot>
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Daniel Haven's personal website" />
    <meta name="generator" content={Astro.generator} />
    <title>{title ?? "Daniel Haven"}</title>
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900 antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-white focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:shadow"
      >Skip to main content</a
    >
    <main
      id="main-content"
      class="mx-auto flex max-w-7xl flex-col items-center gap-10 px-4 py-12 max-[380px]:px-4 max-[380px]:py-8 sm:px-6 sm:py-12"
    >
      <slot />
    </main>
  </body>
</html>
