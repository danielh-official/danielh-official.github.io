---
import SoftwareProductLayout from "@/layouts/SoftwareProductLayout.astro";

function generateMailToLink(subject: string, body: string) {
  return `mailto:d-haven@outlook.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
}

const lastUpdated = new Date("2026-03-30 12:00:00");
---

<SoftwareProductLayout
  title="Privacy Policy - Things Tag Manager: Free and Open Source Companion App for Things 3 (Cultured Code)"
  favicon="https://raw.githubusercontent.com/danielh-official/ThingsTagManager/refs/heads/main/AppIcon-iOS-Default-128x128%401x.png"
  appName="Things Tag Manager"
  backUrl="/things-tag-manager"
>
  <section
    class="flex w-full max-w-xl flex-col gap-4"
    aria-labelledby="privacy-heading"
  >
    <h1 id="privacy-heading" class="m-0 text-2xl font-bold tracking-tight">
      Privacy Policy &mdash; Things Tag Manager
    </h1>
    <p class="m-0 text-xs text-gray-500">
      Last updated: {lastUpdated.toLocaleDateString()}
    </p>
  </section>

  <section class="flex w-full max-w-xl flex-col gap-4">
    <p class="m-0 text-sm text-gray-600">
      Things Tag Manager does not collect, transmit, or share any of your data.
      All tag data, imported from Things 3, stays on your Mac. There are no
      servers, no analytics, and no third-party tracking tools.
    </p>

    <p class="m-0 text-sm text-gray-600">
      Questions? Reach out via <a
        href={generateMailToLink(
          `Question About Privacy Policy (Last Updated: ${lastUpdated.toLocaleDateString()}) for Things Tag Manager`,
          "I have a question about the privacy policy for Things Tag Manager.\n\n{Replace this line with your question.}",
        )}>email</a
      >. This policy may be updated over time; the date above will always
      reflect the latest version.
    </p>
  </section>
</SoftwareProductLayout>
