---
import Layout from "@/layouts/MainLayout.astro";
import wakeupgetupIcon from "@/assets/wakeupgetup/icon.png";
import redditQuickBlockIcon from "@/assets/reddit-quick-block/icon.png";
import ProjectCard from "@/components/ProjectCard.astro";
---

<Layout title="Software Dev Stuff — Daniel Haven">
  <nav aria-label="Breadcrumb">
    <a href="/">&larr; Return to Home Page</a>
  </nav>

  <header class="flex flex-col items-center gap-2 text-center">
    <h1 id="software-heading" class="m-0 text-2xl font-bold tracking-tight">
      Things I've built or am building
    </h1>
  </header>

  <h2 class="text-lg font-semibold">Apps</h2>

  <!-- Grid -->
  <div
    id="app-project-grid"
    role="region"
    aria-labelledby="software-heading-apps"
    class="grid w-full max-w-5xl grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3"
  >
    <ProjectCard
      icon="https://raw.githubusercontent.com/danielh-official/ThingsTagManager/refs/heads/main/AppIcon-iOS-Default-128x128%401x.png"
      name="Things Tag Manager"
      url="/things-tag-manager"
      distributionChannels={["App Store"]}
      pricing="Free"
      openSource={true}
      platforms={["macOS"]}
    >
      A companion app for <a
        href="https://culturedcode.com/things/"
        target="_blank"
        rel="noopener noreferrer">Things 3 (Cultured Code)</a
      > to make managing tags easier.
    </ProjectCard>

    <ProjectCard
      icon={wakeupgetupIcon}
      name="Wake Up, Get Up"
      url="/wakeupgetup"
      distributionChannels={["App Store"]}
      pricing="Free"
      openSource={false}
      platforms={["iOS"]}
    >
      Track the time between waking up and actually getting out of bed.
    </ProjectCard>
  </div>

  <h2 class="text-lg font-semibold">Websites</h2>

  <div
    id="website-project-grid"
    role="region"
    aria-labelledby="software-heading-websites"
    class="grid w-full max-w-5xl grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3"
  >
    <ProjectCard
      icon="https://raw.githubusercontent.com/danielh-official/billsforynab/refs/heads/main/src/lib/assets/favicon.png"
      name="Bills (For YNAB)"
      url="https://billsforynab.com"
      pricing="Free"
      openSource={true}
      platforms={["Web"]}
    >
      A web app for tracking bills (recurring expenses) with YNAB.
    </ProjectCard>

    <ProjectCard
      icon="https://danielhaven.com/ynabapidocs/_app/immutable/assets/favicon.Cr2iNLzt.png"
      name="YNAB API Docs"
      url="https://danielhaven.com/ynabapidocs"
      pricing="Free"
      openSource={true}
      platforms={["Web"]}
    >
      A scraper and web app for YNAB's API documentation that adds statistical
      insights for libraries and integrations.
    </ProjectCard>

    <ProjectCard
      icon="https://raw.githubusercontent.com/danielh-official/streaksforynab/refs/heads/main/src/lib/assets/icons/favicon.png"
      name="Streaks (For YNAB)"
      url="https://danielhaven.com/streaksforynab/"
      pricing="Free"
      openSource={true}
      platforms={["Web"]}
    >
      A web app for tracking spending habits with YNAB.
    </ProjectCard>
  </div>

  <h2 class="text-lg font-semibold">Chrome Extensions</h2>

  <div
    id="chrome-extension-project-grid"
    role="region"
    aria-labelledby="software-heading-chrome-extensions"
    class="grid w-full max-w-5xl grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3"
  >
    <ProjectCard
      icon={redditQuickBlockIcon}
      name="1-click block redditors"
      url="https://chromewebstore.google.com/detail/1-click-block-redditors/gnafilgmiflpdmgdoondecomfikbanda?hl=en"
      distributionChannels={["Chrome Web Store"]}
      pricing="Free"
      openSource={false}
      platforms={["Chrome Extension"]}
    >
      <div>Block a Redditor the exact moment you see his or her hot take.</div>

      <div>
        <img
          alt="Chrome Web Store Users - 1-click block redditors"
          src="https://img.shields.io/chrome-web-store/users/gnafilgmiflpdmgdoondecomfikbanda"
        />
      </div>
    </ProjectCard>

    <ProjectCard
      icon="https://raw.githubusercontent.com/danielh-official/rumble-thumbnails-hider/refs/heads/main/public/icon/128.png"
      name="Hide Rumble Thumbnails"
      url="https://chromewebstore.google.com/detail/hide-rumble-thumbnails/dfmdfkeldajmnkngihdambfpmjfhhbmc"
      distributionChannels={["Chrome Web Store"]}
      pricing="Free"
      openSource={true}
      platforms={["Chrome Extension"]}
    >
      <div>Block distracting, clickbaity thumbnails on Rumble.</div>

      <div>
        <img
          alt="Chrome Web Store Users - Hide Rumble Thumbnails"
          src="https://img.shields.io/chrome-web-store/users/dfmdfkeldajmnkngihdambfpmjfhhbmc"
        />
      </div>
    </ProjectCard>

    <ProjectCard
      icon="https://lh3.googleusercontent.com/DxMNeVY4efYbHgzRV1nKBOM5xdOD2DgkU7C8XPy6mmicqMahbmaqTlq-OFtuxeVf-XTF6pp8bJZ5514lbZP4K7xDrA=s60"
      name="(Unofficial) Save to Play"
      url="https://chromewebstore.google.com/detail/unofficial-save-to-play/gdkaciebpaiikdhopaddmnpeoiedmfdj"
      distributionChannels={["Chrome Web Store"]}
      pricing="Free"
      openSource={true}
      platforms={["Chrome Extension"]}
    >
      <div>Save YouTube videos to Play app.</div>

      <div>
        <img
          alt="Chrome Web Store Users - (Unofficial) Save to Play"
          src="https://img.shields.io/chrome-web-store/users/gdkaciebpaiikdhopaddmnpeoiedmfdj"
        />
      </div>
    </ProjectCard>
  </div>

  <!-- Empty state -->
  <p id="empty-state" class="hidden text-sm text-gray-400">
    No projects in this category yet.
  </p>
</Layout>
