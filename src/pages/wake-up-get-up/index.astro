---
import Layout from "@/layouts/MainLayout.astro";
import wakeupgetupIcon from "@/assets/wakeupgetup/icon.png";
import ContentView9Days from "@/assets/wakeupgetup/screenshots/ContentView9Days.png";
import HistoryView9Days from "@/assets/wakeupgetup/screenshots/HistoryView9Days.png";
import AddLog from "@/assets/wakeupgetup/screenshots/AddLog.png";
import SettingsView from "@/assets/wakeupgetup/screenshots/SettingsView.png";
import ScreenshotFrame from "@/components/ScreenshotFrame.astro";
import { Image } from "astro:assets";
---

<Layout title="Wake Up, Get Up" noFooter>
  <link slot="favicon" rel="icon" type="image/png" href={wakeupgetupIcon.src} />

  <section
    class="flex w-full max-w-xl flex-col items-center gap-6 text-center"
    aria-labelledby="wugu-heading"
  >
    <div class="flex flex-col items-center gap-4">
      <Image
        src={wakeupgetupIcon}
        alt="Wake Up, Get Up app icon"
        class="h-20 w-20 rounded-3xl shadow-sm"
        loading="lazy"
      />
      <div class="space-y-2">
        <h1 id="wugu-heading" class="m-0 text-2xl font-bold tracking-tight">
          Wake Up, Get Up
        </h1>
        <p class="m-0 text-sm text-gray-600">
          Track the time between waking up and actually getting out of bed.
        </p>
        <p class="m-0 text-sm text-gray-500">
          Ever wondered how long you spend doomscrolling before your day really
          starts?
        </p>
        <p class="m-0 text-sm text-gray-500">Log it here.</p>
      </div>
    </div>

    <div
      class="flex w-full flex-row items-center justify-center gap-3 sm:w-auto"
    >
      <a
        href="https://apps.apple.com/us/app/wake-up-get-up/id6758530375?itscg=30200&itsct=apps_box_badge&mttnsubad=6758530375"
        style="display: inline-block;"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Download Wake Up, Get Up on the App Store (opens in new tab)"
      >
        <img
          src="https://toolbox.marketingtools.apple.com/api/v2/badges/download-on-the-app-store/black/en-us?releaseDate=1773187200"
          alt="Download on the App Store"
          style="width: 246px; height: 82px; vertical-align: middle; object-fit: contain;"
        />
      </a>
    </div>
  </section>

  <section
    class="mt-10 flex w-full max-w-xl flex-col gap-4"
    aria-labelledby="features-heading"
  >
    <h2
      id="features-heading"
      class="text-center text-lg font-bold sm:text-left"
    >
      Features
    </h2>
    <ul class="list-inside list-disc space-y-3 text-sm text-gray-600">
      <li>
        <strong>Simple Entry</strong> &mdash; Log when you <span
          class="font-medium">wake up</span
        > and when you <span class="font-medium">get out of bed</span>.
      </li>
      <li>
        <strong>Charts</strong> &mdash; See the last 7 days average of your duration
        in bed as well as a 7-day chart.
      </li>
      <li>
        <strong>Notifications</strong> &mdash; Set a daily reminder to log your wake-up
        and get-up times.
      </li>
      <li>
        <strong>Apple Shortcuts Actions</strong> &mdash; Extend Wake Up, Get Up's
        functionality
        <ul class="list-circle ml-5 list-inside pt-3 text-sm text-gray-600">
          <li>Add Log &mdash; Add a new log for a given date.</li>
          <li>Update Log &mdash; Update a log for a given date.</li>
          <li>Find Log &mdash; Find a log for a given date.</li>
          <li>Get Logs &mdash; Get all logs up to a limit.</li>
        </ul>
      </li>
    </ul>

    <div class="text-center">
      <a
        href="/wakeupgetup/shortcuts"
        class="text-blue-600 hover:text-blue-700 hover:underline focus-visible:outline focus-visible:outline-offset-2 focus-visible:outline-blue-600"
        >Here's a list of some shortcuts you can use.</a
      >
    </div>
  </section>

  <section
    class="mt-8 flex w-full flex-col gap-4"
    aria-labelledby="screenshots-heading"
  >
    <h2
      id="screenshots-heading"
      class="text-center text-lg font-bold sm:text-left"
    >
      Screenshots
    </h2>

    <div
      role="region"
      aria-label="App screenshots"
      class="screenshot-carousel flex w-full snap-x snap-mandatory flex-nowrap items-stretch gap-4 overflow-x-auto [-webkit-overflow-scrolling:touch] sm:grid sm:flex-none sm:grid-cols-4 sm:overflow-visible"
    >
      <div class="screenshot-card shrink-0 snap-start sm:min-w-0">
        <ScreenshotFrame
          src={ContentView9Days}
          alt="Content View - 9 Days"
          caption="Home screen - add log for today and view charts"
        />
      </div>
      <div class="screenshot-card shrink-0 snap-start sm:min-w-0">
        <ScreenshotFrame
          src={HistoryView9Days}
          alt="History View - 9 Days"
          caption="History screen - view all your logs"
        />
      </div>
      <div class="screenshot-card shrink-0 snap-start sm:min-w-0">
        <ScreenshotFrame
          src={AddLog}
          alt="Add Log"
          caption="Add Log screen - simply add wake up and get up times and optionally add a note"
        />
      </div>
      <div class="screenshot-card shrink-0 snap-start sm:min-w-0">
        <ScreenshotFrame
          src={SettingsView}
          alt="Settings View"
          caption="Settings screen - configure a daily reminder to log your wake up and get up times"
        />
      </div>
    </div>
  </section>

  <style>
    .screenshot-card {
      max-height: 65vh;
      width: calc(65vh * 9 / 19);
      min-width: calc(65vh * 9 / 19);
      display: flex;
    }
    .screenshot-carousel {
      max-height: 65vh;
      display: flex;
      width: auto;
      overflow-x: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
      &::-webkit-scrollbar {
        display: none;
      }
    }
  </style>

  <section
    class="mt-10 flex w-full max-w-xl flex-col gap-3"
    aria-labelledby="more-info-heading"
  >
    <h2
      id="more-info-heading"
      class="text-center text-lg font-bold sm:text-left"
    >
      More Information
    </h2>
    <div class="text-sm text-gray-600">
      To learn how "<b>Wake Up, Get Up</b>" uses your data, check out the <a
        href="/wakeupgetup/privacy"
        class="text-blue-600 hover:text-blue-700 hover:underline focus-visible:outline focus-visible:outline-offset-2 focus-visible:outline-blue-600"
        >app's privacy policy</a
      >.
    </div>
  </section>

  <section
    class="mt-10 flex w-full max-w-xl flex-col items-center gap-3 border-t border-gray-100 pt-6"
    aria-labelledby="about-heading"
  >
    <h2 id="about-heading" class="text-center text-lg font-bold sm:text-left">
      About Daniel Haven, the developer
    </h2>
    <p class="text-sm text-gray-600">
      Wake Up, Get Up is currently being built and maintained by one person.
    </p>
    <p class="text-center text-2xl" aria-hidden="true">👋🏻</p>
    <div class="mt-4 flex flex-wrap items-center justify-center gap-3 text-sm">
      Find me on:
      <a
        href="https://github.com/danielh-official"
        target="_blank"
        rel="noopener noreferrer"
      >
        GitHub
      </a>
      <span class="text-gray-300" aria-hidden="true">•</span>
      <a
        href="https://x.com/danielhaven0"
        target="_blank"
        rel="noopener noreferrer"
      >
        X (Twitter)
      </a>
      <span class="text-gray-300" aria-hidden="true">•</span>
      <a href="/" target="_blank" rel="noopener noreferrer"> My Website </a>
    </div>
  </section>
</Layout>
